{
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:hugo": "node scripts/dev-hugo.mjs",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-git-data.ps1 && vite build",
    "build:landing": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-git-data.ps1 && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "hugo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-git-data.ps1 && hugo server -D",
    "hugo:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-git-data.ps1 && hugo"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.462.0",
    "motion": "^12.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  },
  "devDependencies": {}
